{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(bash scripts/commit-module.sh:*)",
      "Bash(./vendor/bin/phpunit*)",
      "Bash(php database/migrate.php*)",
      "Bash(composer install*)",
      "Bash(composer require*)",
      "Bash(mysql -u root*)",
      "Bash(git push*)",
      "Bash(git rm*)",
      "Bash(git branch*)",
      "Bash(git worktree*)",
      "Bash(grep*)",
      "Bash(find*)",
      "Bash(ls*)",
      "Bash(sed*)",
      "Bash(rm*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/session-start.sh" },
          { "type": "command", "command": "bash .claude/hooks/check-migrations.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/docs-index.sh" },
          { "type": "command", "command": "bash .claude/hooks/check-migrations.sh" }
        ]
      }
    ]
  }
}
